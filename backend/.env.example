# Variables de entorno — backend (copiar a `.env` en desarrollo)

# SQLite local (por defecto)
DATABASE_URL=sqlite:///./shekina.db

# Producción Render (PostgreSQL — Render inyecta esto automáticamente)
# DATABASE_URL=postgresql://user:pass@host/plantdesk

SECRET_KEY=genera-un-secreto-largo-y-aleatorio

# Orígenes CORS separados por coma (solo si frontend y API están en dominios distintos)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sembrar usuarios y datos demo si la BD está vacía
SEED_DEMO=false

# Servir PWA compilada desde backend/static (producción monolito Render)
SERVE_STATIC=false
